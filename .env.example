# ── VisibleHand environment variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev / CI):
DATABASE_URL=sqlite:///visiblehand.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/visiblehand
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── External data sources ─────────────────────────────────────────────────────
# FRED (free): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ACLED — register at developer.acleddata.com (non-commercial only without paid license)
# See DATA_SOURCES.md and TERMS_OF_USE.md before commercial use.
ACLED_API_KEY=
ACLED_EMAIL=

# ── Auth & rate limiting ──────────────────────────────────────────────────────
# If set, callers must send X-API-Key header. Leave blank for open public access.
API_KEY=
RATE_LIMIT=120/minute

# ── NLP ──────────────────────────────────────────────────────────────────────
# Path to ONNX model directory. Run: python scripts/export_finbert_onnx.py
NLP_MODEL_DIR=models/finbert-onnx
# Fallback HF model name if ONNX not available:
NLP_MODEL=ProsusAI/finbert

# ── Ingestion ─────────────────────────────────────────────────────────────────
INGESTION_ENABLED=true
INGESTION_HOUR_UTC=2
HTTP_TIMEOUT=30.0
HTTP_MAX_RETRIES=3

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development          # production | development
STRUCTURED_LOGGING=false         # true = JSON logs (recommended for production)
PROMETHEUS_ENABLED=true          # exposes /metrics for Prometheus scraping

# Sentry error tracking — free tier at sentry.io
SENTRY_DSN=

# ── Scoring ───────────────────────────────────────────────────────────────────
SCORE_CACHE_TTL=3600
SCORING_ROLLING_WINDOW=10
